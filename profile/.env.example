# 复制为 .env 并填入真实值
TUSHARE_TOKEN=your_tushare_token_here
# 管理员 Key（=X-API-Key）：完整权限，可改因子权重/归一窗口、触发回测
API_KEY=your_strong_random_api_key_here
# 用户 Key（可选，访客权限）：可查看/选股/读情绪/查看回测结果，禁止改配置和运行全市场预计算；留空则不启用用户 Key
# 未输入 token 时 Web 按访客隐藏管理员入口；服务已配置管理员 Key 时，未授权请求仍会被拒绝
USER_API_KEY=
CACHE_DIR=/app/cache
CACHE_TTL_DAYS=7
DATA_DIR=/app/data
# 日终数据安全线与服务端自动收口；交易日 16:00 首次执行，失败按 5/15/30 分钟退避重试
MARKET_FINAL_READY_TIME=16:00
DAILY_FINALIZE_ENABLED=true
DAILY_FINALIZE_POLL_SECONDS=30
# 留空=本地 SQLite；上云填 RDS：mysql+pymysql://user:pwd@host:3306/stock_agent?charset=utf8mb4
DB_URL=
PRICE_HIKE_FUTURES=

# 服务端量化盯盘：默认每60秒扫描；可在前端设置页持久化调整为30~600秒
QUANT_WATCH_INTERVAL_SECONDS=60
# 通知默认关闭；仅在前端显式启用后使用，真实 webhook 只放 .env/云端 Secret
QUANT_WATCH_FEISHU_WEBHOOK=
QUANT_WATCH_WECOM_WEBHOOK=
