# 复制为 .env 并填入真实值
TUSHARE_TOKEN=your_tushare_token_here
# 管理员 Key（=X-API-Key）：完整权限，可改因子权重/归一窗口、触发回测
API_KEY=your_strong_random_api_key_here
# 用户 Key（可选，只读体验）：可查看/选股/读情绪，禁止改配置与触发回测；留空则不启用用户 Key
USER_API_KEY=
CACHE_DIR=/app/cache
CACHE_TTL_DAYS=7
DATA_DIR=/app/data
# 留空=本地 SQLite；上云填 RDS：mysql+pymysql://user:pwd@host:3306/stock_agent?charset=utf8mb4
DB_URL=
PRICE_HIKE_FUTURES=
